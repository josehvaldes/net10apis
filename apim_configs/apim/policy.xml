<policies>
    <inbound>
        <base />
        <set-backend-service id="apim-generated-policy" backend-id="WebApp_wa-helloworld-test-05" />
        <validate-jwt header-name="Authorization" failed-validation-httpcode="401" output-token-variable-name="jwt">
            <openid-config url="https://cognito-idp.us-east-2.amazonaws.com/us-east-2_Pk3wIVLtP/.well-known/openid-configuration" />
            <required-claims>
                <claim name="token_use">
                    <value>access</value>
                </claim>
            </required-claims>
        </validate-jwt>
        <choose>
            <when condition="@(
                ((Jwt)context.Variables["jwt"]).Claims["scope"]
                    .Any(c => c.Contains("smartapi01/write"))
            )" />
            <otherwise>
                <return-response>
                    <set-status code="403" reason="Forbidden" />
                    <set-body>Missing required scope</set-body>
                </return-response>
            </otherwise>
        </choose>
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>